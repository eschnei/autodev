{
  "client_name": "AcmeCo",
  "bot_identity": {
    "name": "autodev-bot",
    "email": "autodev-bot@example.com"
  },

  "repo": {
    "local_path": "/absolute/path/to/client/repo",
    "url": "https://github.com/AcmeCo/their-repo",
    "default_branch": "main",
    "feature_branch_prefix": "feature/",
    "story_branch_prefix": "autodev"
  },

  "merge_policy": {
    "story_to_feature": "squash",
    "feature_to_main": "merge_commit"
  },

  "tracker": {
    "kind": "linear",
    "mcp": "mcp__linear",
    "_note": "Use the CLIENT's OWN Linear workspace/team (connected via their auth). Never a different workspace.",
    "team": "{{LINEAR_TEAM}}",
    "team_key": "{{LINEAR_TEAM_KEY}}",
    "api_token_env": "LINEAR_API_TOKEN",
    "mapping": {
      "feature": "Linear Project",
      "epic": "Linear Milestone (within the feature's Project)",
      "story": "Linear Issue (assigned to its milestone)",
      "dependency": "Linear issue relation (blocks / blocked_by)"
    },
    "state_model": "label",
    "_state_model_note": "Linear MCP creates labels but not custom statuses, so the engine's authoritative pipeline stage is a stage:* LABEL on the issue, mapped to a coarse native status for the human board. If the client adds custom Linear statuses, set state_model to 'status' and fill statuses below.",
    "stage_labels": {
      "prd_review": "stage:prd-review",
      "breakdown": "stage:breakdown",
      "ready_for_ai_dev": "stage:ready-for-ai-dev",
      "ai_development": "stage:ai-development",
      "ai_qa": "stage:ai-qa",
      "ready_for_human_review": "stage:human-review",
      "ready_for_human_acceptance": "stage:human-acceptance",
      "approved_merge": "stage:approved-merge",
      "failed_human_qa": "stage:failed-human-qa",
      "done": "stage:done",
      "blocked": "stage:blocked"
    },
    "status_map": {
      "Backlog": ["prd_review", "breakdown"],
      "Todo": ["ready_for_ai_dev"],
      "In Progress": ["ai_development", "ai_qa", "ready_for_human_review", "ready_for_human_acceptance", "approved_merge", "failed_human_qa", "blocked"],
      "Done": ["done"]
    },
    "labels": {
      "ai_eligible": "ai-eligible",
      "route_feature": "route:feature",
      "route_task": "route:task",
      "route_bug": "route:bug",
      "risk_classes": ["risk:trivial", "risk:standard", "risk:sensitive"]
    }
  },

  "braingrid": {
    "project_short_id": "PROJ-XX"
  },

  "execution": {
    "max_lanes": 5,
    "tick_interval_minutes": 15,
    "max_dev_qa_loops": 3,
    "self_review_rounds": 1
  },

  "commands": {
    "install": "meteor npm install",
    "test": "meteor npm test",
    "lint": "meteor npm run lint",
    "build": "meteor build --debug",
    "app_run": "meteor run",
    "app_url": "http://localhost:3000"
  },

  "qa": {
    "live_browser": "advisory",
    "e2e_framework": "cypress",
    "e2e_dir": "e2e",
    "live_browser_driver": "playwright_mcp"
  },

  "review": {
    "granularity": "per_story",
    "_granularity_note": "per_story = human reviews each story (calibration). per_feature = stories auto-merge to the feature branch on AI-QA pass; the human acceptance-tests the WHOLE feature and signs off → main (the PM/dev-team model). Start per_story for the first feature, then flip to per_feature.",
    "auto_merge_to_feature_branch": false,
    "_auto_merge_note": "true once granularity is per_feature — stories merge to the feature branch without per-story human review (still gated by AI QA + CI; human gate moves to feature acceptance)."
  },

  "personas": {
    "_note": "Which agent personas the engine may use (subagent slugs in ~/.claude/agents/), and how it routes work to the best one. Roster + routing are per-client because stacks differ. Specialist QA agents are from the agency-agents library.",
    "roster": [
      "product-manager",
      "project-manager-senior",
      "software-architect",
      "backend-architect",
      "frontend-developer",
      "architect-ux",
      "ui-designer",
      "database-optimizer",
      "git-workflow-master",
      "devops-automator",
      "codebase-onboarding-engineer",
      "code-reviewer",
      "evidence-collector",
      "reality-checker",
      "test-results-analyzer",
      "api-tester",
      "application-security-engineer",
      "general-purpose"
    ],
    "stage_defaults": {
      "prd": "product-manager",
      "breakdown": "project-manager-senior"
    },
    "dev_routing": [
      { "match": "server/", "persona": "backend-architect", "why": "Elixir/Phoenix · GraphQL/Absinthe · Ecto" },
      { "match": "ui/", "persona": "frontend-developer", "why": "React 18 · TypeScript · Apollo · MUI · Formik" },
      { "match": "schema|migration|ecto|query|index", "persona": "database-optimizer", "why": "DB schema / query work" },
      { "match": "design|theme|css|component-library", "persona": "architect-ux", "why": "design system / CSS architecture" },
      { "match": "default", "persona": "general-purpose", "why": "fallback when no clear specialist" }
    ],
    "qa_angles": {
      "_note": "Each story is verified by three independent, fresh-context QA runs (all always run); the live browser check is advisory evidence, never a gate.",
      "conformance": ["code-reviewer", "test-results-analyzer", "evidence-collector"],
      "adversarial": ["application-security-engineer", "api-tester"],
      "regression": ["test-results-analyzer", "reality-checker"],
      "verdict": "reality-checker",
      "live_evidence": "evidence-collector"
    }
  },

  "runner": {
    "home_dir": "~/autodev",
    "heartbeat_file": "~/autodev/heartbeat",
    "rate_limited_file": "~/autodev/rate-limited-until",
    "logs_dir": "~/autodev/logs"
  }
}
